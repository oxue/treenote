{
  "name": "treenote",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:viewer": "vite build --config vite.viewer.config.js",
    "build": "npm run build:viewer && vite build",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder",
    "screenshot": "node scripts/take-screenshots.mjs",
    "screenshot:login": "node scripts/take-screenshots.mjs login-page",
    "screenshot:tree": "node scripts/take-screenshots.mjs main-tree",
    "screenshot:children": "node scripts/take-screenshots.mjs tree-with-children",
    "screenshot:queue": "node scripts/take-screenshots.mjs queue-bar"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@supabase/supabase-js": "^2.97.0",
    "capacitor-widget-bridge": "^8.1.0",
    "gemoji": "^8.1.0",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.treenote.app",
    "productName": "Treenote",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": "dmg"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
